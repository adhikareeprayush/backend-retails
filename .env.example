# Environment
NODE_ENV=development

# Server
PORT=5000

# Database
MONGODB_URI=mongodb://localhost:27017/backend-mart
# For MongoDB Atlas, use:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/backend-mart

# JWT Secret Keys
JWT_SECRET=your-super-secret-jwt-key-here
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-here
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Email Configuration (for password reset, notifications, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads/

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS — comma-separated browser origins allowed to call this API (scheme + host, no path).
# Production: list every frontend that uses fetch/XHR from the browser, e.g.:
# ALLOWED_ORIGINS=https://my-app.vercel.app,https://www.mycompany.com
# Also respected (merged into the allowlist): API_PUBLIC_URL, PUBLIC_SITE_URL, STREAMLIT_PUBLIC_URL
# VERCEL_URL is added automatically on Vercel. Requests without an Origin header (curl, Streamlit server, etc.) are not blocked by CORS.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501
# Legacy single-origin (optional if ALLOWED_ORIGINS is set):
CORS_ORIGIN=http://localhost:3000

# Public URL of this API (optional; helps Swagger “Try it” and CORS allowlist)
# API_PUBLIC_URL=https://your-api.vercel.app

# Optional: marketing site or Streamlit community URL if you call the API from browser JS there
# PUBLIC_SITE_URL=https://www.mycompany.com
# STREAMLIT_PUBLIC_URL=https://your-app.streamlit.app

# Streamlit tester (local): export STREAMLIT_API_BASE_URL=https://your-api.vercel.app before streamlit run

# Vercel (set in Project Settings → Environment Variables)
# MONGODB_URI, JWT_SECRET, JWT_REFRESH_SECRET, ALLOWED_ORIGINS / API_PUBLIC_URL
# VERCEL=1 is injected automatically; logs use console-only on Vercel.
#
# Vercel routing matches lms-backend: vercel.json rewrites all paths → api/index.js, which default-exports
# the app from src/server.js. See api/index.js and vercel.json.
# Static UI files in public/ are served via Express GET / on serverless (express.static is skipped there).